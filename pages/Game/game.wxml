<!-- pages/Game/game.wxml -->

<view class="chat-container">
  <!-- 顶部状态栏占位符 -->
  <view class="header-placeholder"></view>
  <view class="workflow-id-placeholder"></view>

  <!-- 顶部状态栏 -->
  <view class="header">
    <view class="status-section">
      <view class="title-with-avatar">
        <view class="avatar-container-small" bindtap="chooseAvatar">
          <image
            class="agent-avatar-small {{currentAvatar ? '' : 'avatar-empty'}}"
            src="{{currentAvatar || ''}}"
            mode="aspectFill"
          ></image>
          <view class="avatar-tip-small" wx:if="{{!currentAvatar}}">+</view>
        </view>
        <text class="welcome-title {{isConnected ? 'connected' : 'disconnected'}}">是或不是</text>
      </view>
    </view>
    <view class="header-actions">
      <button class="action-btn history-btn" bindtap="toggleHistoryPanel">
        <text>📜 历史</text>
      </button>
      <button class="action-btn clear-chat-btn" bindtap="clearChat">
        <text>💬 开启新游戏</text>
      </button>
    </view>
  </view>

  <!-- 头像选择弹窗 -->
  <view class="avatar-modal {{showAvatarModal ? 'show' : ''}}" wx:if="{{showAvatarModal}}">
    <view class="avatar-modal-mask" bindtap="closeAvatarModal"></view>
    <view class="avatar-modal-content">
      <view class="avatar-modal-header">
        <text class="avatar-modal-title">选择头像</text>
        <view class="avatar-modal-close" bindtap="closeAvatarModal">×</view>
      </view>
      <scroll-view class="avatar-modal-body" scroll-y>
        <view class="avatar-grid">
          <view
            class="avatar-grid-item {{currentAvatar === item.path ? 'selected' : ''}}"
            wx:for="{{displayedAvatars}}"
            wx:key="path"
            bindtap="selectAvatar"
            data-path="{{item.path}}"
          >
            <image class="avatar-grid-image" src="{{item.path}}" mode="aspectFill"></image>
            <view class="avatar-selected-icon" wx:if="{{currentAvatar === item.path}}">✓</view>
            <view class="avatar-delete-btn" wx:if="{{item.isCustom}}" catchtap="deleteCustomAvatar" data-index="{{index}}">
              <text>×</text>
            </view>
          </view>
          <view class="avatar-grid-item avatar-upload-btn" bindtap="uploadAvatar">
            <view class="avatar-upload-content">
              <text class="avatar-upload-icon">+</text>
              <text class="avatar-upload-text">上传</text>
            </view>
          </view>
        </view>
        <view class="avatar-more-btn" bindtap="showMoreAvatars" wx:if="{{hasMoreAvatars}}">
          <text>查看更多</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 历史记录面板 -->
  <view class="history-panel {{showHistoryPanel ? 'show' : ''}}" wx:if="{{showHistoryPanel}}">
    <view class="history-panel-content" catchtap="stopPropagation">
      <view class="history-header">
        <text class="history-title">📜 游戏历史记录</text>
        <button class="close-btn" bindtap="toggleHistoryPanel">×</button>
      </view>
      <scroll-view class="history-list" scroll-y>
        <view class="history-empty" wx:if="{{chatHistory.length === 0}}">
          <text>暂无历史记录</text>
        </view>
        <view class="history-item" wx:for="{{chatHistory}}" wx:key="conversationId" bindtap="loadHistory" data-index="{{index}}">
          <view class="history-item-header">
            <text class="history-agent">{{item.agentName}}</text>
            <text class="history-conversation-id">会话ID: {{item.conversationId.substring(0, 8)}}...</text>
          </view>
          <text class="history-preview">{{item.preview}}</text>
          <view class="history-item-footer">
            <text class="history-time">{{item.timeString}}</text>
            <view class="history-delete" catchtap="deleteHistory" data-index="{{index}}">🗑️ 删除</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- <text class="workflow-id">智能体ID : {{agent_id || '未设置'}}
    会话ID : {{conversation_id || '未设置'}}</text> -->

  <!-- 聊天消息列表 -->
  <scroll-view class="messages-container" scroll-y scroll-top="{{scrollTop}}" scroll-with-animation>
    <!-- Loading indicator -->
    <view class="loading-indicator" wx:if="{{receivedData && !isReceivingDone}}">
      <text class="loading-text">🤖 AI正在输入</text>
      <view class="loading-dots">
        <text class="dot">.</text>
        <text class="dot">.</text>
        <text class="dot">.</text>
      </view>
    </view>

    <view class="message-item {{item.type}}-message" wx:for="{{chatMessages}}" wx:key="id">
      <view class="avatar {{item.type}}-avatar">{{item.type === 'user' ? '我' : 'AI'}}</view>
      <view class="message-bubble {{item.type}}-bubble">
        <view class="bubble-header" wx:if="{{item.type === 'ai'}}">
          <text class="bubble-time">{{item.timestamp}}</text>
          <text class="copy-btn" bindtap="copyMessage" data-content="{{item.result_content}}">📋 复制</text>
        </view>
        <view class="thinking-section" wx:if="{{item.type === 'ai' && item.history_isexpanded}}">
          <text class="thinking-text">{{item.thinking_content}}</text>
        </view>
        <view class="thinking-toggle" bindtap="change_history_isexpanded" data-index="{{index}}" wx:if="{{item.type === 'ai'}}">
          <text class="toggle-text">{{item.history_isexpanded ? '👆 收起思考过程' : '👇 展开思考过程'}}</text>
        </view>
        <text class="message-text">{{item.result_content}}</text>
        <view class="bubble-footer" wx:if="{{item.type === 'user'}}">
          <text class="bubble-time">{{item.timestamp}}</text>
          <text class="copy-btn" bindtap="copyMessage" data-content="{{item.result_content}}">📋 复制</text>
        </view>
      </view>
    </view>

    <!-- 当前正在接收的消息 -->
    <view class="message-item ai-message" wx:if="{{receivedData && !isReceivingDone}}">
      <view class="avatar ai-avatar">AI</view>
      <view class="thinking-container">
        <text class="thinking-content" wx:if="{{isexpanded}}">
          {{thinkingdata}}
        </text>
        <text bindtap="changeisexpanded" wx:if="{{isexpanded}}">
          👉点击折叠思考过程
        </text>
        <view class="thinking-content" bindtap="changeisexpanded" wx:if="{{!isexpanded}}">
          <text>👉 点击展开思考过程</text>
        </view>
      </view>
      <view class="message-bubble ai-bubble">
        <text class="message-text">{{resultdata}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 答题按钮区域（仅答题模式显示） -->
  <view class="answer-buttons-area" wx:if="{{showAnswerButtons}}">
    <view class="answer-buttons-row">
      <button class="answer-btn" bindtap="sendAnswer" data-answer="是">是</button>
      <button class="answer-btn" bindtap="sendAnswer" data-answer="不是">不是</button>
    </view>
    <view class="answer-buttons-row">
      <button class="answer-btn" bindtap="sendAnswer" data-answer="可能是">可能是</button>
      <button class="answer-btn" bindtap="sendAnswer" data-answer="可能不是">可能不是</button>
    </view>
    <view class="answer-buttons-row">
      <button class="answer-btn answer-btn-wide" bindtap="sendAnswer" data-answer="不知道">不知道</button>
    </view>
  </view>

  <!-- 输入区域（答题模式时隐藏） -->
  <view class="input-area" wx:if="{{!inputAreaDisabled}}">
    <textarea
      class="chat-input textarea-input"
      placeholder="输入消息..."
      value="{{inputMessage}}"
      bindinput="onInputMessageChange"
      auto-height
      maxlength="500"
    />
    <button class="send-button send-btn-short" bindtap="sendMessage" disabled="{{!inputMessage || !isConnected}}">
      <text class="send-text">发送</text>
    </button>
  </view>

  <!-- 开始游戏弹窗 -->
  <view class="game-modal {{showStartModal ? 'show' : ''}}" wx:if="{{showStartModal}}">
    <view class="game-modal-mask" bindtap="closeStartModal"></view>
    <view class="game-modal-content">
      <view class="game-modal-header">
        <text class="game-modal-title">游戏邀请</text>
        <view class="game-modal-close" bindtap="closeStartModal">×</view>
      </view>
      <view class="game-modal-body">
        <text class="game-modal-text">您要游玩是或不是吗？</text>
      </view>
      <view class="game-modal-footer">
        <button class="game-modal-btn game-modal-btn-secondary" bindtap="closeStartModal">取消</button>
        <button class="game-modal-btn game-modal-btn-primary" bindtap="startGame">开始</button>
      </view>
    </view>
  </view>

  <!-- 模式选择弹窗 -->
  <view class="game-modal {{showModeSelection ? 'show' : ''}}" wx:if="{{showModeSelection}}">
    <view class="game-modal-mask" bindtap="closeModeSelection"></view>
    <view class="game-modal-content">
      <view class="game-modal-header">
        <text class="game-modal-title">选择模式</text>
        <view class="game-modal-close" bindtap="closeModeSelection">×</view>
      </view>
      <view class="game-modal-body">
        <button class="mode-select-btn" bindtap="selectMode" data-mode="guess">
          <text class="mode-select-icon">🔮</text>
          <text class="mode-select-text">我来猜猜你想什么</text>
        </button>
        <button class="mode-select-btn" bindtap="selectMode" data-mode="answer">
          <text class="mode-select-icon">🎯</text>
          <text class="mode-select-text">你来猜猜我想什么</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 游戏结束弹窗 -->
  <view class="game-modal {{showGameEndModal ? 'show' : ''}}" wx:if="{{showGameEndModal}}">
    <view class="game-modal-mask" bindtap="closeGameEndModal"></view>
    <view class="game-modal-content">
      <view class="game-modal-header">
        <text class="game-modal-title">游戏结束</text>
        <view class="game-modal-close" bindtap="closeGameEndModal">×</view>
      </view>
      <view class="game-modal-body">
        <text class="game-modal-text">游戏已结束，您想要？</text>
      </view>
      <view class="game-modal-footer">
        <button class="game-modal-btn" bindtap="handleGameEndChoice" data-choice="summary">总结本次游戏</button>
        <button class="game-modal-btn game-modal-btn-secondary" bindtap="handleGameEndChoice" data-choice="nothing">暂时不用</button>
      </view>
    </view>
  </view>
</view>
